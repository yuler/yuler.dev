---
import AgentsContent, { frontmatter } from '../../AGENTS.md'
import rawAgentsMd from '../../AGENTS.md?raw'
import MarkdownProse from '../components/MarkdownProse.astro'
import Switch from '../components/Switch.astro'
import Layout from '../layouts/Layout.astro'

const agentsDescription = typeof frontmatter?.description === 'string' && frontmatter.description.trim()
  ? frontmatter.description.trim()
  : 'at repository root.'
---

<Layout title="Agents" description="Rendered AGENTS.md for yuler.dev agent instructions.">
  <div class="min-h-screen bg-[#f5f5f5] text-gray-900">
    <div class="max-w-4xl mx-auto px-4 py-8 md:py-12">
      <nav class="flex items-center gap-1.5 text-xs sm:text-sm text-gray-500 mb-6 sm:mb-8 font-mono">
        <a href="/" class="hover:text-gray-900 transition-colors">~</a>
        <span class="text-gray-300">/</span>
        <span class="text-gray-900">agents</span>
      </nav>

      <div class="bg-white border border-gray-200 p-6 md:p-8 mb-6">
        <div class="mb-2 flex items-center justify-between gap-3">
          <h1 class="text-2xl md:text-3xl font-bold font-mono text-gray-900">AGENTS.md</h1>
          <Switch
            switchId="render-mode-switch"
            ariaLabel="Render mode"
            value="preview"
            eventName="render-mode:change"
            options={[
              { label: 'Preview', value: 'preview' },
              { label: 'Markdown', value: 'markdown' },
            ]}
          />
        </div>
        <p class="text-sm text-gray-500 font-mono mb-5">
          {agentsDescription}
        </p>
      </div>

      <div
        class="bg-white border border-gray-200 p-6 md:p-8"
        data-render-root
        data-render-switch="render-mode-switch"
        data-mode="preview"
      >
        <section data-mode-panel="preview">
          <MarkdownProse>
            <AgentsContent />
          </MarkdownProse>
        </section>

        <section id="markdown-text" data-mode-panel="markdown" class="hidden">
          <pre class="overflow-x-auto border border-gray-300 bg-gray-100 p-4 text-sm text-gray-800 leading-relaxed"><code>{rawAgentsMd}</code></pre>
        </section>
      </div>
    </div>
  </div>
</Layout>

<script>
  import '../scripts/render-mode'
</script>
