---
import Layout from '../../layouts/Layout.astro'
import CornerMarkers from '../../components/CornerMarkers.astro'
import ChevronRight from '../../components/icons/ChevronRight.astro'
import ChevronDown from '../../components/icons/ChevronDown.astro'
import { formatDate } from '../../utils/date'
import { loadAllStoredActivities } from '../../utils/strava-activities'
import type { StoredActivitySummary } from '../../utils/strava-activities'
import {
  formatDistanceMetersCompact,
  formatMovingDuration,
  formatPaceOrSpeed,
  sportIcons,
} from '../../utils/workout-display'
import { getWeekRangesWithIndex } from '../../utils/week-grid'

const activities = loadAllStoredActivities<StoredActivitySummary>()

activities.sort((a, b) => new Date(b.start_date_local).getTime() - new Date(a.start_date_local).getTime())

const currentYear = new Date().getFullYear()
const allWeeks = getWeekRangesWithIndex(currentYear)

const activityDates = new Set(activities.map(a => formatDate(new Date(a.start_date_local))))
const weeks = allWeeks.filter(({ start, end }) =>
  [...activityDates].some(d => d >= start && d <= end),
)
---

<Layout title="Workouts — Yu Le">
  <div class="min-h-screen bg-[#f5f5f5] text-gray-900">
    <div class="max-w-4xl mx-auto px-4 py-8 md:py-12">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-1.5 text-xs sm:text-sm text-gray-500 mb-6 sm:mb-8 font-mono">
        <a href="/" class="hover:text-gray-900 transition-colors">~</a>
        <span class="text-gray-300">/</span>
        <span class="text-gray-900">workouts</span>
      </nav>

      <!-- Week Filter -->
      <div class="mb-4 bg-white border border-gray-200 px-3 py-2 sm:px-4 sm:py-3 relative">
        <CornerMarkers />
        <div class="flex items-center justify-between gap-2">
          <button
            id="week-prev"
            class="px-2 py-1.5 text-xs sm:text-sm text-gray-400 hover:text-gray-900 transition-colors font-mono disabled:opacity-30 disabled:cursor-not-allowed min-h-11 min-w-11"
          >
            ← Prev
          </button>
          <div class="flex flex-col gap-2 items-center">
            <div class="relative flex items-center">
              <select
                id="week-select"
                class="appearance-none bg-transparent border border-gray-200 hover:border-gray-300 text-xs sm:text-sm font-mono text-gray-900 py-1 pl-2 pr-7 cursor-pointer transition-colors focus:outline-none focus:border-gray-400"
              >
                <option value="">All weeks</option>
                {
                  weeks.map(w => (
                    <option value={`${w.start}~${w.end}`}>
                      W{String(w.index).padStart(2, '0')}: {w.start} ~ {w.end}
                    </option>
                  ))
                }
              </select>
              <ChevronDown class="absolute right-2.5 w-2.5 h-2.5 sm:w-3.5 sm:h-3.5 text-gray-400 pointer-events-none" />
            </div>
            <span
              id="filter-count"
              class="text-xs text-gray-400 font-mono whitespace-pre-line sm:whitespace-normal text-center sm:text-left leading-[1.1] sm:leading-normal"
            ></span>
          </div>
          <button
            id="week-next"
            class="px-2 py-1.5 text-xs sm:text-sm text-gray-400 hover:text-gray-900 transition-colors font-mono disabled:opacity-30 disabled:cursor-not-allowed min-h-11 min-w-11"
          >
            Next →
          </button>
        </div>
      </div>

      <!-- Main Card -->
      <div class="relative bg-white border border-gray-200 p-4 sm:p-6">
        <CornerMarkers />

        <!-- Header -->
        <div class="mb-6 flex items-center justify-between border-b border-gray-100 pb-4">
          <h1 class="text-lg font-semibold text-gray-900 font-mono">Workouts</h1>
          <span id="activity-count" class="px-2 py-0.5 text-sm bg-gray-100 text-gray-600 font-mono">
            {activities.length} activities
          </span>
        </div>

        <ul id="activity-list" class="space-y-1">
          {
            activities.map(activity => (
              <li data-date={formatDate(new Date(activity.start_date_local))}>
                <a
                  href={`/workouts/${activity.id}`}
                  class="group flex items-center justify-between p-3 min-h-[3.25rem] transition-colors hover:bg-gray-50 border border-transparent hover:border-gray-200"
                >
                  <div class="flex items-center gap-3 min-w-0">
                    <span class="text-lg shrink-0" title={activity.sport_type}>
                      {sportIcons[activity.sport_type] || '💪'}
                    </span>
                    <div class="min-w-0">
                      <h3 class="font-medium text-gray-900 group-hover:text-gray-700 truncate">{activity.name}</h3>
                      <div class="flex items-center gap-2 text-xs text-gray-500 font-mono mt-0.5 min-w-0 overflow-hidden whitespace-nowrap">
                        <time datetime={activity.start_date_local} class="shrink-0 whitespace-nowrap">
                          {formatDate(new Date(activity.start_date_local))}
                        </time>
                        <span class="text-gray-300 shrink-0">|</span>
                        <span class="shrink-0 whitespace-nowrap">{formatDistanceMetersCompact(activity.distance)}</span>
                        <span class="text-gray-300 shrink-0">|</span>
                        <span class="shrink-0 whitespace-nowrap">
                          {formatMovingDuration(activity.moving_time, 'list')}
                        </span>
                        <span class="hidden sm:inline text-gray-300 shrink-0">|</span>
                        <span class="hidden sm:inline shrink-0 whitespace-nowrap">
                          {formatPaceOrSpeed(activity.sport_type, activity.average_speed)}
                        </span>
                      </div>
                    </div>
                  </div>
                  <ChevronRight class="h-4 w-4 text-gray-400 shrink-0 transition-transform group-hover:translate-x-0.5" />
                </a>
              </li>
            ))
          }
        </ul>

        <!-- Empty state -->
        <div id="empty-state" class="hidden py-12 text-center text-gray-400 font-mono text-sm">
          No activities this week
        </div>

        <!-- Footer -->
        <div
          class="mt-6 pt-4 border-t border-gray-100 flex items-center justify-between text-xs text-gray-400 font-mono"
        >
          <span>
            Powered by{' '}
            <a
              href="https://www.strava.com/"
              target="_blank"
              rel="noopener noreferrer"
              class="underline! underline-offset-2 decoration-gray-300 hover:decoration-gray-500 hover:text-gray-600 transition-colors"
            >
              Strava
            </a>
          </span>
          <a href="/" class="hover:text-gray-600 transition-colors">← Home</a>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    ;(function () {
      var select = document.getElementById('week-select')
      var prevBtn = document.getElementById('week-prev')
      var nextBtn = document.getElementById('week-next')
      var countEl = document.getElementById('filter-count')
      var activityCount = document.getElementById('activity-count')
      var emptyState = document.getElementById('empty-state')
      var items = document.querySelectorAll('#activity-list > li')
      var total = items.length

      function applyFilter(from, to) {
        var visible = 0
        items.forEach(function (li) {
          var date = li.getAttribute('data-date')
          if (!from || (date >= from && date <= to)) {
            li.style.display = ''
            visible++
          } else {
            li.style.display = 'none'
          }
        })
        countEl.textContent = from ? visible + ' matched' : ''
        activityCount.textContent = (from ? visible : total) + (visible === 1 ? ' activity' : ' activities')
        emptyState.classList.toggle('hidden', visible > 0)

        var idx = select.selectedIndex
        prevBtn.disabled = idx <= 1
        nextBtn.disabled = idx <= 0 || idx >= select.options.length - 1
      }

      function setWeek(value) {
        select.value = value
        if (value) {
          var parts = value.split('~')
          applyFilter(parts[0], parts[1])
          history.replaceState(null, '', '?from=' + parts[0] + '&to=' + parts[1])
        } else {
          applyFilter(null, null)
          history.replaceState(null, '', window.location.pathname)
        }
      }

      select.addEventListener('change', function () {
        setWeek(select.value)
      })

      prevBtn.addEventListener('click', function () {
        var idx = select.selectedIndex
        if (idx > 1) setWeek(select.options[idx - 1].value)
      })

      nextBtn.addEventListener('click', function () {
        var idx = select.selectedIndex
        if (idx > 0 && idx < select.options.length - 1) setWeek(select.options[idx + 1].value)
      })

      // Init from URL params
      var params = new URLSearchParams(window.location.search)
      var from = params.get('from')
      var to = params.get('to')
      if (from && to) {
        setWeek(from + '~' + to)
      } else {
        prevBtn.disabled = true
        nextBtn.disabled = true
      }
    })()
  </script>
</Layout>
