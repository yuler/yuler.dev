---
import type { StoredActivitySummary } from '../../utils/strava-activities'
import CornerMarkers from '../../components/CornerMarkers.astro'
import ChevronRight from '../../components/icons/ChevronRight.astro'
import WorkoutsDateRangeSelector from '../../components/WorkoutsDateRangeSelector.astro'
import Layout from '../../layouts/Layout.astro'
import { formatDate } from '../../utils/date'
import { loadAllStoredActivities } from '../../utils/strava-activities'
import {
  formatDistanceMetersCompact,
  formatMovingDuration,
  formatPaceOrSpeed,
  sportIcons,
} from '../../utils/workout-display'

const activities = loadAllStoredActivities<StoredActivitySummary>()

activities.sort((a, b) => new Date(b.start_date_local).getTime() - new Date(a.start_date_local).getTime())

const todayStr = formatDate(new Date())

const YMD = /^\d{4}-\d{2}-\d{2}$/
const isYmd = (s: string | null): s is string => Boolean(s && YMD.test(s))

const urlFrom = Astro.url.searchParams.get('from')
const urlTo = Astro.url.searchParams.get('to')
const initialFrom = isYmd(urlFrom) && isYmd(urlTo) ? urlFrom : null
const initialTo = isYmd(urlFrom) && isYmd(urlTo) ? urlTo : null
---

<Layout title="Workouts — Yu Le">
  <div class="min-h-screen bg-[#f5f5f5] text-gray-900">
    <div class="mx-auto max-w-4xl px-4 py-8 md:py-12">
      <header class="mb-6 space-y-4 sm:mb-8 sm:space-y-5">
        <nav class="flex items-center gap-1.5 font-mono text-xs text-gray-500 sm:text-sm">
          <a href="/" class="transition-colors hover:text-gray-900">~</a>
          <span class="text-gray-300">/</span>
          <span class="text-gray-900">workouts</span>
        </nav>
        <WorkoutsDateRangeSelector initialFrom={initialFrom} initialTo={initialTo} today={todayStr} />
      </header>

      <div class="relative border border-gray-200 bg-white p-4 sm:p-6">
        <CornerMarkers />

        <!-- Header -->
        <div class="mb-6 flex items-center justify-between border-b border-gray-100 pb-4">
          <h1 class="text-lg font-semibold text-gray-900 font-mono">Workouts</h1>
          <span id="activity-count" class="px-2 py-0.5 text-sm bg-gray-100 text-gray-600 font-mono">
            {activities.length} activities
          </span>
        </div>

        <ul id="activity-list" class="space-y-1">
          {
            activities.map(activity => (
              <li data-date={formatDate(new Date(activity.start_date_local))}>
                <a
                  href={`/workouts/${activity.id}`}
                  class="group flex items-center justify-between p-3 min-h-[3.25rem] transition-colors hover:bg-gray-50 border border-transparent hover:border-gray-200"
                >
                  <div class="flex items-center gap-3 min-w-0">
                    <span class="text-lg shrink-0" title={activity.sport_type}>
                      {sportIcons[activity.sport_type] || '💪'}
                    </span>
                    <div class="min-w-0">
                      <h3 class="font-medium text-gray-900 group-hover:text-gray-700 truncate">{activity.name}</h3>
                      <div class="flex items-center gap-2 text-xs text-gray-500 font-mono mt-0.5 min-w-0 overflow-hidden whitespace-nowrap">
                        <time datetime={activity.start_date_local} class="shrink-0 whitespace-nowrap">
                          {formatDate(new Date(activity.start_date_local))}
                        </time>
                        <span class="text-gray-300 shrink-0">|</span>
                        <span class="shrink-0 whitespace-nowrap">{formatDistanceMetersCompact(activity.distance)}</span>
                        <span class="text-gray-300 shrink-0">|</span>
                        <span class="shrink-0 whitespace-nowrap">
                          {formatMovingDuration(activity.moving_time, 'list')}
                        </span>
                        <span class="hidden sm:inline text-gray-300 shrink-0">|</span>
                        <span class="hidden sm:inline shrink-0 whitespace-nowrap">
                          {formatPaceOrSpeed(activity.sport_type, activity.average_speed)}
                        </span>
                      </div>
                    </div>
                  </div>
                  <ChevronRight class="h-4 w-4 text-gray-400 shrink-0 transition-transform group-hover:translate-x-0.5" />
                </a>
              </li>
            ))
          }
        </ul>

        <!-- Empty state -->
        <div id="empty-state" class="hidden py-12 text-center text-gray-400 font-mono text-sm">
          No activities in this range
        </div>
      </div>
    </div>
  </div>
</Layout>
