---
import type { GetStaticPaths } from 'astro'
import type { StoredActivity } from '../../utils/strava-activities'
import CornerMarkers from '../../components/CornerMarkers.astro'
import MapRoute from '../../components/MapRoute.astro'
import ShareWorkout from '../../components/ShareWorkout.astro'
import Layout from '../../layouts/Layout.astro'
import { formatDate } from '../../utils/date'
import { decodePolyline } from '../../utils/polyline'
import { getStoredActivityIds, loadStoredActivityById } from '../../utils/strava-activities'
import { deviceEmoji, formatDistanceMeters, formatMaxSpeedKmh, formatMovingDuration, formatPaceOrSpeed, sportIcons } from '../../utils/workout-display'

export const getStaticPaths: GetStaticPaths = () => {
  return getStoredActivityIds()
    .map((id) => {
      const activity = loadStoredActivityById<StoredActivity>(id)
      if (!activity)
        return null
      return { params: { id: String(id) }, props: { activity } }
    })
    .filter(
      (x): x is { params: { id: string }, props: { activity: StoredActivity } } => x !== null,
    )
}

const { activity } = Astro.props as { activity: StoredActivity }

const polyline = activity.map?.polyline || activity.map?.summary_polyline || ''
const hasMap = polyline.length > 0
const points = hasMap ? decodePolyline(polyline) : []

const stats = [
  { label: 'Distance', value: formatDistanceMeters(activity.distance) },
  { label: 'Moving Time', value: formatMovingDuration(activity.moving_time, 'detail') },
  { label: 'Elapsed Time', value: formatMovingDuration(activity.elapsed_time, 'detail') },
  { label: 'Pace / Speed', value: formatPaceOrSpeed(activity.sport_type, activity.average_speed) },
  { label: 'Max Speed', value: formatMaxSpeedKmh(activity.max_speed) },
  { label: 'Elevation Gain', value: `${activity.total_elevation_gain}m` },
  ...(activity.has_heartrate
    ? [
        { label: 'Avg Heart Rate', value: `${activity.average_heartrate} bpm` },
        { label: 'Max Heart Rate', value: `${activity.max_heartrate} bpm` },
      ]
    : []),
  ...(activity.calories ? [{ label: 'Calories', value: `${activity.calories} kcal` }] : []),
]

const sportIcon = sportIcons[activity.sport_type] || '💪'
const pageUrl = new URL(`workouts/${activity.id}`, Astro.site ?? 'https://yuler.dev/').href
---

<Layout title={`${activity.name} — Workouts`}>
  <div class="min-h-screen bg-[#f5f5f5] text-gray-900">
    <div class="max-w-4xl mx-auto px-4 py-8 md:py-12">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-1.5 text-xs sm:text-sm text-gray-500 mb-6 sm:mb-8 font-mono">
        <a href="/" class="hover:text-gray-900 transition-colors">~</a>
        <span class="text-gray-300">/</span>
        <a href="/workouts" class="hover:text-gray-900 transition-colors">workouts</a>
        <span class="text-gray-300">/</span>
        <span class="text-gray-900 truncate max-w-37.5 sm:max-w-50">{activity.name}</span>
      </nav>

      <!-- Header Card -->
      <div class="bg-white border border-gray-200 p-4 sm:p-6 md:p-8 mb-4 relative">
        <CornerMarkers />

        <div class="flex items-start gap-3 mb-4">
          <span class="text-2xl">{sportIcons[activity.sport_type] || '💪'}</span>
          <div>
            <h1 class="text-2xl md:text-3xl font-bold text-gray-900 font-mono">
              {activity.name}
            </h1>
          </div>
        </div>

        <div class="flex items-center gap-2 text-xs text-gray-500 font-mono mt-1 min-w-0 overflow-hidden whitespace-nowrap">
          <time datetime={activity.start_date_local} class="shrink-0 whitespace-nowrap">
            {formatDate(new Date(activity.start_date_local))}
          </time>
          <span class="text-gray-300 shrink-0">|</span>
          <span class="shrink-0 whitespace-nowrap">{activity.sport_type}</span>
          {
            activity.device_name && (
              <>
                <span class="text-gray-300 shrink-0">|</span>
                <span class="inline-flex items-center gap-1 min-w-0 overflow-hidden text-gray-400">
                  <span class="shrink-0">{deviceEmoji(activity.device_name)}</span>
                  <span class="truncate">{activity.device_name}</span>
                </span>
              </>
            )
          }
        </div>

        {
          activity.description && (
            <p class="text-gray-600 border-l-2 border-gray-300 pl-4 mt-4">{activity.description}</p>
          )
        }
      </div>

      <!-- Map Card -->
      {hasMap && (
        <MapRoute points={points} duration={activity.moving_time} startTime={activity.start_date_local}>
          <ShareWorkout
            slot="header-actions"
            activityId={activity.id}
            activityName={activity.name}
            sportType={activity.sport_type}
            sportIcon={sportIcon}
            date={formatDate(new Date(activity.start_date_local))}
            stats={stats}
            points={points}
            pageUrl={pageUrl}
          />
        </MapRoute>
      )}

      <!-- Stats Card -->
      <div class="bg-white border border-gray-200 p-4 sm:p-6 md:p-8 mb-4 relative">
        <CornerMarkers />

        <h2 class="text-sm font-semibold text-gray-900 font-mono mb-4 pb-3 border-b border-gray-100">Stats</h2>

        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
          {
            stats.map(stat => (
              <div class="p-3 bg-gray-50 border border-gray-100">
                <div class="text-xs text-gray-400 font-mono mb-1">{stat.label}</div>
                <div class="text-lg font-semibold text-gray-900 font-mono">{stat.value}</div>
              </div>
            ))
          }
        </div>
      </div>

      <!-- Navigation Footer -->
      <div class="flex items-center justify-between bg-white border border-gray-200 p-4 relative">
        <CornerMarkers />

        <a
          href="/workouts"
          class="inline-flex items-center gap-2 px-4 py-2 min-h-11 text-sm text-gray-500 hover:text-gray-900 transition-colors font-mono"
        >
          <span>←</span>
          <span>All workouts</span>
        </a>

        <a
          href={`https://www.strava.com/activities/${activity.id}`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-4 py-2 min-h-11 text-sm text-gray-500 hover:text-gray-900 transition-colors font-mono"
        >
          <span>View on Strava</span>
          <span>↗</span>
        </a>
      </div>
    </div>
  </div>
</Layout>
