---
import type { GetStaticPaths, Page } from 'astro'
import type { CollectionEntry } from 'astro:content'
import { getCollection } from 'astro:content'

import ChevronRight from '../../components/icons/ChevronRight.astro'

import Layout from '../../layouts/Layout.astro'
import { formatDate } from '../../utils/date'

interface Props {
  page: Page<CollectionEntry<'posts'>>
}

const { page } = Astro.props

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const posts = (
    await getCollection('posts', ({ data }) => {
      return import.meta.env.PROD ? data.draft !== true : true
    })
  ).sort((a, b) => (b.data.date > a.data.date ? 1 : -1))

  return paginate(posts, { pageSize: 10 })
}
---

<Layout title="Posts — Yu Le">
  <div class="min-h-screen bg-[#f5f5f5] text-gray-900">
    <div class="max-w-4xl mx-auto px-4 py-8 md:py-12">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-1.5 text-xs sm:text-sm text-gray-500 mb-6 sm:mb-8 font-mono">
        <a href="/" class="hover:text-gray-900 transition-colors">~</a>
        <span class="text-gray-300">/</span>
        <span class="text-gray-900">posts</span>
      </nav>
      <!-- Main Card -->
      <div class="relative bg-white border border-gray-200 p-4 sm:p-6">
        <!-- Corner Markers -->
        <div class="absolute -top-px -left-px w-2 h-2 border-t border-l border-gray-400"></div>
        <div class="absolute -top-px -right-px w-2 h-2 border-t border-r border-gray-400"></div>
        <div class="absolute -bottom-px -left-px w-2 h-2 border-b border-l border-gray-400"></div>
        <div class="absolute -bottom-px -right-px w-2 h-2 border-b border-r border-gray-400"></div>

        <!-- Header -->
        <div class="mb-6 flex items-center justify-between border-b border-gray-100 pb-4">
          <h1 class="text-lg font-semibold text-gray-900 font-mono">Posts</h1>
          <span class="px-2 py-0.5 text-sm bg-gray-100 text-gray-600 font-mono">
            {page.currentPage}/{page.lastPage}
          </span>
        </div>

        <ul class="space-y-1">
          {
            page.data.map(post => (
              <li>
                <a
                  href={`/posts/${post.id}`}
                  class="group flex min-h-13 items-start justify-between gap-3 p-3 transition-colors hover:bg-gray-50 border border-transparent hover:border-gray-200"
                >
                  <div class="min-w-0">
                    <h3 class="font-medium text-gray-900 group-hover:text-gray-700">
                      {post.data.title}
                      {post.data.draft && (
                        <span class="ml-2 px-1.5 py-0.5 text-xs bg-gray-200 text-gray-600">Draft</span>
                      )}
                      {post.data.wip && <span class="ml-2 px-1.5 py-0.5 text-xs bg-amber-100 text-amber-700">WIP</span>}
                    </h3>
                    <p class="mt-1 line-clamp-2 text-sm leading-snug text-gray-600">
                      {post.data.description}
                    </p>
                    <div class="mt-2 flex flex-wrap items-center gap-2">
                      <time class="text-xs text-gray-500 font-mono" datetime={post.data.date.toISOString()}>
                        {formatDate(post.data.date)}
                      </time>
                      {post.data.tags.slice(0, 4).map(tag => (
                        <span class="border border-gray-200 px-1.5 py-0.5 text-[10px] leading-none text-gray-500">
                          {tag}
                        </span>
                      ))}
                    </div>
                  </div>
                  <ChevronRight class="mt-1 h-4 w-4 shrink-0 text-gray-400 transition-transform group-hover:translate-x-0.5" />
                </a>
              </li>
            ))
          }
        </ul>

        {
          (page.url.prev || page.url.next) && (
            <div class="mt-8 flex items-center justify-between border-t border-gray-100 pt-6">
              {page.url.prev
? (
                <a
                  href={page.url.prev}
                  class="inline-flex min-h-11 items-center gap-2 px-4 py-3 text-sm bg-gray-100 text-gray-600 hover:bg-gray-200 hover:text-gray-900 transition-colors font-mono"
                >
                  <span>←</span>
                  <span>Prev</span>
                </a>
              )
: (
                <span />
              )}

              <span class="text-sm text-gray-400 font-mono">
                {page.currentPage}/{page.lastPage}
              </span>

              {page.url.next
? (
                <a
                  href={page.url.next}
                  class="inline-flex min-h-11 items-center gap-2 px-4 py-3 text-sm bg-gray-100 text-gray-600 hover:bg-gray-200 hover:text-gray-900 transition-colors font-mono"
                >
                  <span>Next</span>
                  <span>→</span>
                </a>
              )
: (
                <span />
              )}
            </div>
          )
        }
      </div>
    </div>
  </div>
</Layout>
