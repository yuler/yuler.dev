---
import CornerMarkers from './CornerMarkers.astro'
import Globe from './icons/Globe.astro'
import LocateFixed from './icons/LocateFixed.astro'
import MapFold from './icons/MapFold.astro'
import Pause from './icons/Pause.astro'
import Play from './icons/Play.astro'
import 'leaflet/dist/leaflet.css'

interface Props {
  points: number[][]
  duration?: number
  startTime?: string
}

const { points, duration = 0, startTime = '' } = Astro.props

const randomId = Math.random().toString(36).slice(2, 9)
const mapId = `activity-map-${randomId}`
const btnId = `play-route-btn-${randomId}`
const resetBtnId = `reset-map-btn-${randomId}`
const switchBtnId = `switch-provider-btn-${randomId}`
---

<div class="bg-white border border-gray-200 mb-4 relative">
  <CornerMarkers class="z-1000" />

  <div class="p-4 border-b border-gray-100 flex items-center justify-between">
    <div class="flex items-center gap-3">
      <h2 class="text-sm font-semibold text-gray-900 font-mono">Route</h2>
      <button
        id={switchBtnId}
        class="text-gray-400 hover:text-gray-900 transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-gray-400 focus-visible:ring-offset-2 rounded-sm cursor-pointer"
        aria-label="Switch map provider"
        title="Switch map provider"
      >
        <Globe class="size-3.5 provider-icon-carto" />
        <MapFold class="size-3.5 provider-icon-amap hidden" />
      </button>
    </div>
    <div class="flex items-center gap-4">
      <slot name="header-actions" />
      <button
        id={btnId}
        class="text-gray-400 hover:text-gray-900 transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-gray-400 focus-visible:ring-offset-2 rounded-sm cursor-pointer"
        aria-label="Play route trace"
        title="Play route trace"
      >
        <Play class="play-icon" />
        <Pause class="pause-icon hidden" />
      </button>
    </div>
  </div>
  <div class="relative">
    <div
      id={mapId}
      class="h-62.5 sm:h-75 md:h-100 w-full activity-map-container"
      data-points={JSON.stringify(points)}
      data-duration={duration}
      data-start-time={startTime}
      data-btn-id={btnId}
      data-reset-btn-id={resetBtnId}
      data-switch-btn-id={switchBtnId}
    >
    </div>
    <button
      id={resetBtnId}
      class="reset-map-btn absolute bottom-2 left-2 z-1000 flex items-center justify-center bg-white/95 p-0 text-gray-600 hover:bg-white hover:text-gray-900 border border-gray-200 rounded-sm shadow-sm transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-gray-400 focus-visible:ring-offset-2 cursor-pointer"
      aria-label="Reset map center"
      title="Reset map center"
    >
      <LocateFixed class="size-[18px]" />
    </button>
  </div>
</div>

<style is:global>
  /* Align zoom with top-left inset; same as Tailwind gap-2 (0.5rem) as reset bottom-left */
  .activity-map-container .leaflet-top.leaflet-left .leaflet-control {
    margin-top: 0.5rem;
    margin-left: 0.5rem;
  }

  /* Leaflet default is 2px on touch; use 1px like Tailwind `border` */
  .activity-map-container.leaflet-touch .leaflet-bar {
    border-width: 1px;
  }

  /* Same cell size as Leaflet default (26×26); override touch 30×30 so reset + zoom match */
  .activity-map-container .leaflet-bar a {
    width: 26px;
    height: 26px;
    line-height: 26px;
  }

  .activity-map-container.leaflet-touch .leaflet-control-zoom-in,
  .activity-map-container.leaflet-touch .leaflet-control-zoom-out {
    font-size: 1.125rem;
  }

  .activity-map-container + .reset-map-btn {
    width: 26px;
    height: 26px;
    box-sizing: border-box;
  }
</style>

<script>
import type { BasemapProvider } from '../lib/leafletTiles'
import { addSeconds, format } from 'date-fns'
import L from 'leaflet'
import {
  addLightBasemapTiles,
  BASEMAP_CHANGED_EVENT,

  getProvider,
  LEAFLET_MAP_OPTIONS_ACTIVITY_ROUTE,
  resolveBasemapProvider,
  syncProviderIcon,
  toggleProvider,
  toMapCoords,
} from '../lib/leafletTiles'

const MAP_BOUNDS_PADDING: L.PointExpression = [28, 28]

/** 高德绿地/黄路多，细绿线易糊；白晕 + 深色粗线更易读。Carto 浅色底单层即可。 */
const ROUTE_POLYLINE_BASE: Pick<L.PolylineOptions, 'lineCap' | 'lineJoin' | 'smoothFactor'> = {
  lineCap: 'round',
  lineJoin: 'round',
  smoothFactor: 1.35,
}

const ROUTE_BY_PROVIDER: Record<
  BasemapProvider,
  { halo: L.PolylineOptions | null, main: L.PolylineOptions }
> = {
  amap: {
    halo: {
      ...ROUTE_POLYLINE_BASE,
      color: '#ffffff',
      weight: 12,
      opacity: 0.5,
      interactive: false,
    },
    main: {
      ...ROUTE_POLYLINE_BASE,
      color: '#059669',
      weight: 4,
      opacity: 1,
    },
  },
  carto: {
    halo: null,
    main: {
      ...ROUTE_POLYLINE_BASE,
      color: '#10b981',
      weight: 4,
      opacity: 0.9,
    },
  },
}

function addRoutePolylines(map: L.Map, latlngs: L.LatLng[], provider: BasemapProvider): L.Polyline {
  const { halo, main } = ROUTE_BY_PROVIDER[provider]
  if (halo)
    L.polyline(latlngs, halo).addTo(map)
  return L.polyline(latlngs, main).addTo(map)
}

const liveAbort = new Map<string, AbortController>()
const liveMaps = new Map<string, L.Map>()

async function initActivityMaps() {
  await resolveBasemapProvider()
  document.querySelectorAll<HTMLElement>('.activity-map-container').forEach(initSingleMap)
}

function initSingleMap(el: HTMLElement) {
  const pointsData = el.getAttribute('data-points')
  if (!pointsData)
    return

  let rawPoints: number[][]
  try {
    rawPoints = JSON.parse(pointsData)
  }
  catch (e) {
    console.error('Failed to parse route points:', e)
    return
  }
  if (!Array.isArray(rawPoints) || rawPoints.length === 0)
    return

  const duration = Number.parseInt(el.getAttribute('data-duration') || '0', 10)
  let startTimeStr = el.getAttribute('data-start-time') || ''
  // start_date_local is local time but may include a trailing "Z".
  // Strip "Z" so browsers don't parse it as UTC and shift displayed elapsed time.
  if (startTimeStr.endsWith('Z'))
    startTimeStr = startTimeStr.slice(0, -1)

  const mapId = el.id
  const btnId = el.getAttribute('data-btn-id')
  const resetBtnId = el.getAttribute('data-reset-btn-id')
  const switchBtnId = el.getAttribute('data-switch-btn-id')

  // Tear down previous instance (for provider-switch re-init)
  liveAbort.get(mapId)?.abort()
  liveMaps.get(mapId)?.remove()

  const ac = new AbortController()
  const { signal } = ac
  liveAbort.set(mapId, ac)

  const latlngs = rawPoints.map((p: number[]) => {
    const [lat, lng] = toMapCoords(p[0], p[1])
    return L.latLng(lat, lng)
  })

  const map = L.map(mapId, {
    zoomControl: true,
    attributionControl: true,
    ...LEAFLET_MAP_OPTIONS_ACTIVITY_ROUTE,
  })
  liveMaps.set(mapId, map)

  addLightBasemapTiles(map, { labels: true })

  const routeLine = addRoutePolylines(map, latlngs, getProvider())

  addMarker(map, latlngs[0], '#10b981')
  const endLatLng = latlngs.at(-1)
  if (endLatLng)
    addMarker(map, endLatLng, '#ef4444')

  map.fitBounds(routeLine.getBounds(), { padding: MAP_BOUNDS_PADDING, animate: false })

  const homeCenter = map.getCenter()
  const homeZoom = map.getZoom()

  setupMotionPlayer(map, latlngs, btnId, duration, startTimeStr, signal)
  setupResetCenter(map, homeCenter, homeZoom, resetBtnId, signal)
  setupProviderSwitch(switchBtnId, signal)

  el.dataset.routeReady = 'true'
}

// ── Provider switch ──────────────────────────────────────────────────────

function setupProviderSwitch(switchBtnId: string | null, signal: AbortSignal) {
  if (!switchBtnId)
    return
  const btn = document.getElementById(switchBtnId)
  if (!btn)
    return

  syncProviderIcon(btn, getProvider())
  btn.addEventListener('click', () => toggleProvider(), { signal })
}

document.addEventListener(BASEMAP_CHANGED_EVENT, () => {
  const provider = getProvider()
  document.querySelectorAll<HTMLElement>('[id^="switch-provider-btn-"]').forEach((b) => {
    syncProviderIcon(b, provider)
  })
  document.querySelectorAll<HTMLElement>('.activity-map-container').forEach(initSingleMap)
})

// ── Helpers ──────────────────────────────────────────────────────────────

function addMarker(map: L.Map, position: L.LatLngExpression, color: string) {
  const html = `<div style="width:0.75rem;height:0.75rem;background:${color};border:0.125rem solid white;border-radius:50%;box-shadow:0 0.0625rem 0.1875rem rgba(0,0,0,0.3)"></div>`
  L.marker(position, {
    icon: L.divIcon({ html, className: '', iconSize: [12, 12], iconAnchor: [6, 6] }),
  }).addTo(map)
}

function setupMotionPlayer(
  map: L.Map,
  pathPoints: L.LatLng[],
  actionBtnId: string | null,
  motionDuration: number,
  initialTimeStr: string,
  signal: AbortSignal,
) {
  const motionBtn = actionBtnId ? document.getElementById(actionBtnId) : null
  if (!motionBtn)
    return

  const playIcon = motionBtn.querySelector('.play-icon')
  const pauseIcon = motionBtn.querySelector('.pause-icon')

  let isPlaying = false
  let currentProgress = 0
  let lastTime: number | null = null
  let animationFrameId: number | null = null
  let motionMarker: L.Marker | null = null
  let motionPolyline: L.Polyline | null = null

  const FALLBACK_DURATION_MS = 10000
  /** 1 real minute moving time → 0.5s playback */
  const PLAYBACK_MS_PER_REAL_MINUTE = 500
  const DURATION_MS = motionDuration > 0
    ? Math.max(500, (motionDuration / 60) * PLAYBACK_MS_PER_REAL_MINUTE)
    : FALLBACK_DURATION_MS
  let totalDist = 0
  const dists = [0]
  for (let i = 1; i < pathPoints.length; i++) {
    totalDist += pathPoints[i - 1].distanceTo(pathPoints[i])
    dists.push(totalDist)
  }

  // Reset play button visual on re-init
  playIcon?.classList.remove('hidden')
  pauseIcon?.classList.add('hidden')

  function formatTime(progressSeconds: number) {
    if (initialTimeStr) {
      const dateObj = new Date(initialTimeStr)
      const currentObj = addSeconds(dateObj, progressSeconds)
      return format(currentObj, 'HH:mm:ss')
    }
    const h = Math.floor(progressSeconds / 3600)
    const m = Math.floor((progressSeconds % 3600) / 60)
    const s = Math.round(progressSeconds % 60)
    return h > 0
      ? `${h}:${String(m).padStart(2, '0')}:${String(s).padStart(2, '0')}`
      : `${m}:${String(s).padStart(2, '0')}`
  }

  function togglePlayPause() {
    if (isPlaying) {
      if (animationFrameId != null)
        cancelAnimationFrame(animationFrameId)
      isPlaying = false
      playIcon?.classList.remove('hidden')
      pauseIcon?.classList.add('hidden')
    }
    else {
      if (currentProgress >= 1)
        currentProgress = 0
      isPlaying = true
      playIcon?.classList.add('hidden')
      pauseIcon?.classList.remove('hidden')
      lastTime = performance.now()

      if (!motionMarker)
        initMotionElements()

      animationFrameId = requestAnimationFrame(animate)
    }
  }

  function initMotionElements() {
    motionMarker = L.marker(pathPoints[0], {
      icon: L.divIcon({
        html: '<div style="width:0.875rem;height:0.875rem;background:#3b82f6;border:0.125rem solid white;border-radius:50%;box-shadow:0 0.0625rem 0.1875rem rgba(0,0,0,0.3)"></div>',
        className: '',
        iconSize: [14, 14],
        iconAnchor: [7, 7],
      }),
      interactive: false,
      zIndexOffset: 1000,
    }).addTo(map)

    if (motionDuration > 0 || initialTimeStr) {
      motionMarker
        .bindTooltip(formatTime(0), {
          permanent: true,
          direction: 'top',
          offset: [0, -10],
          className: 'font-mono text-xs font-semibold',
        })
        .openTooltip()
    }

    motionPolyline = L.polyline([pathPoints[0]], {
      color: '#3b82f6',
      weight: 3,
      opacity: 1,
      smoothFactor: 1,
      interactive: false,
    }).addTo(map)
  }

  function getInterpolatedPoint(targetDist: number): { point: L.LatLng, index: number } {
    let i = 1
    while (i < dists.length && dists[i] < targetDist) i++

    if (i >= dists.length) {
      const lastPt = pathPoints.at(-1)
      return { point: lastPt ?? pathPoints[0], index: pathPoints.length }
    }

    const startDist = dists[i - 1]
    const endDist = dists[i]
    const segmentProgress = (targetDist - startDist) / (endDist - startDist || 1)
    const p1 = pathPoints[i - 1]
    const p2 = pathPoints[i]
    const lat = p1.lat + (p2.lat - p1.lat) * segmentProgress
    const lng = p1.lng + (p2.lng - p1.lng) * segmentProgress

    return { point: L.latLng(lat, lng), index: i }
  }

  function animate(time: number) {
    if (lastTime == null || motionMarker == null || motionPolyline == null)
      return
    const delta = time - lastTime
    lastTime = time
    currentProgress += delta / DURATION_MS

    if (currentProgress >= 1) {
      currentProgress = 1
      isPlaying = false
      playIcon?.classList.remove('hidden')
      pauseIcon?.classList.add('hidden')
    }
    else {
      animationFrameId = requestAnimationFrame(animate)
    }

    const { point, index } = getInterpolatedPoint(currentProgress * totalDist)

    motionMarker.setLatLng(point)
    motionPolyline.setLatLngs([...pathPoints.slice(0, index), point])

    if ((motionDuration > 0 || initialTimeStr) && motionMarker.getTooltip()) {
      const currentSeconds = Math.round(currentProgress * motionDuration)
      motionMarker.setTooltipContent(formatTime(currentSeconds))
    }
  }

  // Stop animation when this map instance is torn down
  signal.addEventListener('abort', () => {
    if (animationFrameId != null)
      cancelAnimationFrame(animationFrameId)
  })

  motionBtn.addEventListener('click', togglePlayPause, { signal })
}

function setupResetCenter(
  map: L.Map,
  homeCenter: L.LatLng,
  homeZoom: number,
  resetActionBtnId: string | null,
  signal: AbortSignal,
) {
  if (!resetActionBtnId)
    return

  const resetBtn = document.getElementById(resetActionBtnId)
  if (!resetBtn)
    return

  resetBtn.addEventListener(
    'click',
    () => {
      map.setView(homeCenter, homeZoom)
    },
    { signal },
  )
}

let resizeTimer: ReturnType<typeof setTimeout>
window.addEventListener('resize', () => {
  clearTimeout(resizeTimer)
  resizeTimer = setTimeout(() => {
    document.querySelectorAll<HTMLElement>('.activity-map-container').forEach(initSingleMap)
  }, 300)
})

if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', initActivityMaps)
}
else {
  initActivityMaps()
}
</script>
