---
// src/components/Thought.astro
import type { ImageMetadata } from 'astro'
import type { CollectionEntry } from 'astro:content'
import { Image } from 'astro:assets'
import { render } from 'astro:content'
import { humanize } from '../utils/date'

interface Props {
  thought: CollectionEntry<'thoughts'>
  /** inline: 原列表条目；sticky: 便签内排版 */
  variant?: 'inline' | 'sticky'
}

const { thought, variant = 'inline' } = Astro.props
const { Content } = await render(thought)

const rootClass
  = variant === 'sticky'
    ? 'py-3 px-0.5'
    : 'py-4 border-b border-gray-100 last:border-0'
---

<div class={rootClass}>
  <div class="flex items-center justify-between mb-2">
    <time class="text-xs text-gray-500 font-mono" datetime={thought.data.date.toISOString()}>
      {humanize(thought.data.date)}
    </time>
    {thought.data.tags && (
      <div class="flex gap-2">
        {thought.data.tags.map((tag: string) => (
          <span
            class:list={[
              'text-xs px-1.5 py-0.5 font-mono',
              variant === 'sticky' ? 'bg-white/55 text-gray-600' : 'bg-gray-100 text-gray-500',
            ]}
          >
            #{tag}
          </span>
        ))}
      </div>
    )}
  </div>

  <div class="prose prose-sm max-w-none text-gray-800 leading-relaxed">
    <Content />
  </div>

  {thought.data.images && thought.data.images.length > 0 && (
    <div class="mt-3 grid gap-2 grid-cols-3 max-w-120">
      {thought.data.images.map((img: ImageMetadata, index: number) => (
        <Image
          src={img}
          alt={`Thought image ${index + 1}`}
          class="border border-gray-200 w-full aspect-square object-cover m-0! transition-all duration-300 hover:border-gray-400 hover:shadow-sm cursor-zoom-in"
          data-lightbox="true"
        />
      ))}
    </div>
  )}
</div>
