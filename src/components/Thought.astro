---
// src/components/Thought.astro
import type { ImageMetadata } from 'astro'
import type { CollectionEntry } from 'astro:content'
import { Image } from 'astro:assets'
import { render } from 'astro:content'
import { format } from 'date-fns'

interface Props {
  thought: CollectionEntry<'thoughts'>
}

const { thought } = Astro.props
const { Content } = await render(thought)

const tags = thought.data.tags ?? []
---

<div class="relative">
  <div class="mb-3 flex items-center justify-between gap-3">
    <time
      class="shrink-0 text-xs tabular-nums text-gray-500"
      datetime={thought.data.date.toISOString()}
    >
      {format(thought.data.date, 'MMM d, yyyy')}
    </time>
    <div class="flex min-w-0 flex-wrap items-center justify-end gap-1.5">
      {tags.length > 0
        ? (
            tags.map((tag: string) => (
              <span class="rounded border border-gray-200/90 bg-gray-50/90 px-1.5 py-0.5 text-xs text-gray-700">
                #{tag.replace(/^#/, '')}
              </span>
            ))
          )
        : (
            <span class="text-xs text-gray-400">—</span>
          )}
    </div>
  </div>

  <div class="thought-content max-w-none text-sm leading-relaxed text-gray-900">
    <Content />
  </div>

  {thought.data.images && thought.data.images.length > 0 && (
    <div class="mt-3 grid max-w-120 grid-cols-3 gap-2">
      {thought.data.images.map((img: ImageMetadata, index: number) => (
        <Image
          src={img}
          alt={`Thought image ${index + 1}`}
          class="m-0! aspect-square w-full cursor-zoom-in rounded border border-gray-200 object-cover transition-all duration-300 hover:border-gray-300"
          data-lightbox="true"
        />
      ))}
    </div>
  )}
</div>

<style>
  .thought-content a {
    @apply text-blue-600 underline hover:text-blue-700;
  }
  .thought-content code {
    @apply rounded bg-gray-100 px-1 py-px text-[0.8125rem];
  }
  .thought-content h2 {
    @apply mb-2 mt-4 text-sm font-semibold text-gray-900;
  }
  .thought-content h3 {
    @apply text-xs font-semibold text-gray-800;
  }
  .thought-content li {
    @apply my-0.5;
  }
  .thought-content p {
    @apply my-2.5;
  }
  .thought-content p:first-child {
    @apply mt-0;
  }
  .thought-content strong {
    @apply font-semibold text-gray-900;
  }
  .thought-content ul {
    @apply my-2;
  }
</style>
