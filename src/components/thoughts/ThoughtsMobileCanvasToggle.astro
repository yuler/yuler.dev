---
---

<div class="mb-5 flex flex-wrap gap-2 md:hidden motion-reduce:hidden">
  <button
    type="button"
    data-thoughts-open-canvas
    class="rounded border border-gray-300 bg-white px-3 py-1.5 text-sm font-mono text-gray-800 shadow-sm hover:border-gray-400"
  >
    在画布上查看
  </button>
  <button
    type="button"
    data-thoughts-close-canvas
    class="hidden rounded border border-gray-300 bg-white px-3 py-1.5 text-sm font-mono text-gray-800 shadow-sm hover:border-gray-400"
  >
    返回列表
  </button>
</div>

<script>
  import { initThoughtsCanvas } from './thoughts-canvas-controller'

  function qs<T extends HTMLElement>(sel: string) {
    return document.querySelector<T>(sel)
  }

  const root = qs<HTMLElement>('#thoughts-root')
  const openBtn = qs<HTMLButtonElement>('[data-thoughts-open-canvas]')
  const closeBtn = qs<HTMLButtonElement>('[data-thoughts-close-canvas]')
  const viewport = qs<HTMLElement>('#thoughts-canvas-viewport')
  const world = qs<HTMLElement>('#thoughts-canvas-world')

  if (root && openBtn && closeBtn && viewport && world) {
    const R = root
    const O = openBtn
    const C = closeBtn
    const V = viewport
    const W = world
    let active: ReturnType<typeof initThoughtsCanvas> | null = null

    function setMobileCanvas(on: boolean) {
      if (on) {
        R.dataset.mobileCanvas = 'true'
        O.classList.add('hidden')
        C.classList.remove('hidden')
        active = initThoughtsCanvas(V, W)
      }
      else {
        R.removeAttribute('data-mobile-canvas')
        O.classList.remove('hidden')
        C.classList.add('hidden')
        active?.destroy()
        active = null
      }
    }

    const mq = window.matchMedia('(min-width: 768px)')
    function resetIfDesktop() {
      if (mq.matches && R.dataset.mobileCanvas === 'true')
        setMobileCanvas(false)
    }

    O.addEventListener('click', () => setMobileCanvas(true))
    C.addEventListener('click', () => setMobileCanvas(false))
    mq.addEventListener('change', resetIfDesktop)
  }
</script>
