---
import type { StoredActivitySummary } from '../../utils/strava-activities'
import { format } from 'date-fns'
import { formatDate } from '../../utils/date'
import { loadAllStoredActivities } from '../../utils/strava-activities'
import { dailyMovingTimeHeatLevel, effectiveMovingSeconds, formatDurationHeatmap } from '../../utils/workout-display'
import { getRollingYearContributionColumns } from '../../utils/workouts-calendar'
import CornerMarkers from '../CornerMarkers.astro'
import ArrowRight from '../icons/ArrowRight.astro'

const WEEKDAY_LABELS = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'] as const

interface Props {
  class?: string
}

const { class: className } = Astro.props

type Activity = Pick<StoredActivitySummary, 'id' | 'name' | 'moving_time' | 'elapsed_time' | 'start_date_local'>

const activities = loadAllStoredActivities<Activity>()

const today = new Date()
const todayStr = formatDate(today)

const rawColumns = getRollingYearContributionColumns(today)
const totalColumns = rawColumns.length
const rangeStartStr = rawColumns[0]?.[0]?.date ?? todayStr
const rangeEndStr = rawColumns.length > 0 ? (rawColumns.at(-1)?.[6]?.date ?? todayStr) : todayStr

const secondsByDate = new Map<string, number>()
const namesByDate = new Map<string, string[]>()

for (const activity of activities) {
  const date = new Date(activity.start_date_local)
  const dateStr = formatDate(date)
  if (dateStr < rangeStartStr || dateStr > rangeEndStr)
    continue

  const sec = effectiveMovingSeconds(activity.moving_time, activity.elapsed_time)
  secondsByDate.set(dateStr, (secondsByDate.get(dateStr) ?? 0) + sec)
  if (!namesByDate.has(dateStr))
    namesByDate.set(dateStr, [])
  namesByDate.get(dateStr)!.push(activity.name)
}

function monthTickLabelForColumn(col: { date: string }[]): string {
  for (const { date } of col) {
    const d = new Date(`${date}T12:00:00`)
    if (d.getDate() === 1)
      return format(d, 'MMM')
  }
  return ''
}

const columnMonthLabels = rawColumns.map(col => monthTickLabelForColumn(col))

function heatmapDayAriaLabel(date: string, durationStr: string, names: string[]): string {
  const count = names.length
  const countPhrase = count === 0 ? 'no activities' : count === 1 ? '1 activity' : `${count} activities`
  let label = `${date}: ${durationStr}, ${countPhrase}`
  if (count > 0) {
    const shown = names.slice(0, 5)
    const suffix = count > shown.length ? `, and ${count - shown.length} more` : ''
    label += `: ${shown.join(', ')}${suffix}`
  }
  return label
}

const columns = rawColumns.map((col, columnIndex) =>
  col.map((day) => {
    const seconds = day.inYear ? (secondsByDate.get(day.date) ?? 0) : 0
    const names = day.inYear ? (namesByDate.get(day.date) ?? []) : []
    const level = day.inYear ? dailyMovingTimeHeatLevel(seconds) : 0
    const isToday = day.date === todayStr
    const isFuture = day.inYear && day.date > todayStr

    return {
      date: day.date,
      inYear: day.inYear,
      columnIndex,
      seconds,
      names,
      level,
      isToday,
      isFuture,
      durationStr: formatDurationHeatmap(seconds),
    }
  }),
)
---

<div
  class={`relative bg-white border border-gray-200 p-6 transition-all duration-300 hover:border-gray-400 ${className}`}
>
  <CornerMarkers />

  <div class="flex flex-col gap-4">
    <!-- Header -->
    <div class="flex items-center justify-between border-b border-gray-100 pb-4">
      <h3 class="text-lg font-semibold text-gray-900 font-mono">Workouts</h3>
      <a
        href="/workouts"
        class="inline-flex items-center gap-1 text-xs text-gray-400 font-mono hover:text-gray-600 transition-colors underline underline-offset-2 decoration-gray-200 hover:decoration-gray-400"
      >
        View all
        <ArrowRight class="h-3 w-3" />
      </a>
    </div>

    <!-- Y-axis fixed; months + cells scroll horizontally (GitHub-style). Tooltip is sibling of scroll (fixed) — see script. -->
    <div class="flex min-w-0 flex-col gap-2">
      <div class="relative flex min-w-0 gap-0.5" data-wk-heatmap-root>
        <div class="wk-axis-col flex shrink-0 flex-col gap-0.5 self-start bg-white pr-0.5">
          <div class="h-4 shrink-0" aria-hidden="true" />
          {
            WEEKDAY_LABELS.map(label => (
              <div class="wk-y-label flex h-2.5 w-7 shrink-0 items-center justify-end pr-1 font-mono text-[9px] leading-none text-gray-500 sm:h-3 sm:w-8">
                {label}
              </div>
            ))
          }
        </div>
        <div
          class="min-w-0 flex-1 overflow-x-auto scroll-smooth pb-0.5"
          data-workout-contrib-scroll
        >
          <div
            class="wk-scroll-grid w-max"
            style={`--wk-col-count: ${totalColumns};`}
          >
            {
              columnMonthLabels.map(monthLabel => (
                <div class="wk-month mb-1 flex items-end justify-center overflow-visible leading-none">
                  <span class="whitespace-nowrap text-center text-[8px] font-mono text-gray-500 sm:text-[9px]">
                    {monthLabel || '\u00A0'}
                  </span>
                </div>
              ))
            }
            {
              WEEKDAY_LABELS.flatMap((_label, rowIndex) =>
                columns.map((weekDays) => {
                  const day = weekDays[rowIndex]
                  const tipPayload = {
                    date: day.date,
                    isFuture: day.isFuture,
                    durationStr: day.durationStr,
                    names: day.names,
                    columnIndex: day.columnIndex,
                    totalColumns,
                  }
                  return (
                    <div
                      class="relative min-h-0 min-w-0"
                      data-wk-tip={JSON.stringify(tipPayload)}
                    >
                      {!day.isFuture
                        ? (
                            <a
                              href={`/workouts?from=${day.date}&to=${day.date}`}
                              aria-label={heatmapDayAriaLabel(day.date, day.durationStr, day.names)}
                              class:list={[
                                'block size-full min-h-0 min-w-0 transition-colors duration-200',
                                day.level > 0 ? 'cursor-pointer' : 'cursor-default',
                                {
                                  'bg-gray-100': day.level === 0,
                                  'bg-gray-300': day.level === 1,
                                  'bg-gray-600': day.level === 2,
                                  'bg-black': day.level === 3,
                                  'ring-1 ring-black/40 ring-inset': day.isToday,
                                },
                              ]}
                            />
                          )
                        : (
                            <div
                              class:list={[
                                'block size-full min-h-0 min-w-0',
                                {
                                  'bg-gray-100 opacity-50': day.isFuture,
                                  'ring-1 ring-black/40 ring-inset': day.isToday,
                                },
                              ]}
                            />
                          )}
                    </div>
                  )
                }),
              )
            }
          </div>
        </div>
        <div class="wk-heatmap-tooltip" aria-hidden="true"></div>
      </div>
      <div class="mt-2 flex flex-row justify-between gap-2 sm:items-center text-[10px] text-gray-400">
        <span>
          Powered by{' '}
          <a
            href="https://www.strava.com/"
            target="_blank"
            rel="noopener noreferrer"
            class="underline! text-xs underline-offset-2 decoration-gray-300 hover:decoration-gray-500 hover:text-gray-600 transition-colors"
          >
            Strava
          </a>
        </span>
        <div class="flex gap-1 items-center flex-wrap">
          <span>Less time</span>
          <div class="flex gap-0.5">
            <div class="size-1.5 bg-gray-100" />
            <div class="size-1.5 bg-gray-300" />
            <div class="size-1.5 bg-gray-600" />
            <div class="size-1.5 bg-black" />
          </div>
          <span>More time</span>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .wk-scroll-grid {
    display: grid;
    gap: 0.125rem;
    grid-template-columns: repeat(var(--wk-col-count), var(--wk-cell, 0.625rem));
    grid-template-rows: 1rem repeat(7, var(--wk-cell, 0.625rem));
    --wk-cell: 0.625rem;
  }
  @media (min-width: 640px) {
    .wk-scroll-grid {
      --wk-cell: 0.75rem;
    }
  }
</style>

<!-- JS appends .wk-heatmap-tooltip__* nodes; scoped Astro CSS would not match them. -->
<style is:global>
  .wk-heatmap-tooltip {
    pointer-events: none;
    position: fixed;
    z-index: 110;
    left: 0;
    top: 0;
    width: max-content;
    max-width: min(13.75rem, calc(100vw - 1rem));
    opacity: 0;
    visibility: hidden;
    transform: scale(0.95);
    transition:
      opacity 0.15s ease,
      transform 0.15s ease,
      visibility 0s linear 0.15s;
  }
  .wk-heatmap-tooltip.wk-heatmap-tooltip--open {
    opacity: 1;
    visibility: visible;
    transform: scale(1);
    transition:
      opacity 0.15s ease,
      transform 0.15s ease,
      visibility 0s linear 0s;
  }
  .wk-heatmap-tooltip__inner {
    position: relative;
    width: max-content;
    max-width: inherit;
  }
  .wk-heatmap-tooltip__panel {
    background: #fff;
    border: 1px solid #e5e7eb;
    padding: 0.25rem 0.5rem;
    font-size: 10px;
    line-height: 1.25;
    color: #111827;
    box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1);
  }
  .wk-heatmap-tooltip__date {
    font-weight: 500;
  }
  .wk-heatmap-tooltip__meta {
    color: #4b5563;
  }
  .wk-heatmap-tooltip__names {
    margin-top: 0.25rem;
    color: #374151;
  }
  .wk-heatmap-tooltip__name {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .wk-heatmap-tooltip__more {
    color: #6b7280;
  }
  .wk-heatmap-tooltip__arrow {
    position: absolute;
    top: 100%;
    width: 0.5rem;
    height: 0.5rem;
    margin-top: -5px;
    transform: translateX(-50%) rotate(45deg);
    background: #fff;
    border-right: 1px solid #e5e7eb;
    border-bottom: 1px solid #e5e7eb;
  }
</style>

<script>
  interface WkTipPayload {
    date: string
    isFuture: boolean
    durationStr: string
    names: string[]
    columnIndex: number
    totalColumns: number
  }

  function parseWkTip(el: HTMLElement): WkTipPayload | null {
    const raw = el.dataset.wkTip
    if (!raw)
      return null
    try {
      return JSON.parse(raw) as WkTipPayload
    }
    catch {
      return null
    }
  }

  function closestWkTip(el: EventTarget | null): HTMLElement | null {
    if (!el || !(el as Node).nodeType)
      return null
    return (el as Element).closest?.('[data-wk-tip]') ?? null
  }

  function fillTooltipContent(bubble: HTMLElement, tip: WkTipPayload) {
    bubble.replaceChildren()
    const inner = document.createElement('div')
    inner.className = 'wk-heatmap-tooltip__inner'

    const panel = document.createElement('div')
    panel.className = 'wk-heatmap-tooltip__panel'

    const dateEl = document.createElement('div')
    dateEl.className = 'wk-heatmap-tooltip__date'
    dateEl.textContent = tip.date

    const meta = document.createElement('div')
    meta.className = 'wk-heatmap-tooltip__meta'
    meta.textContent = tip.isFuture
      ? 'Upcoming'
      : `${tip.durationStr} · ${tip.names.length} ${tip.names.length === 1 ? 'activity' : 'activities'}`

    panel.append(dateEl, meta)

    if (tip.names.length > 0) {
      const namesWrap = document.createElement('div')
      namesWrap.className = 'wk-heatmap-tooltip__names'
      for (const name of tip.names.slice(0, 4)) {
        const row = document.createElement('div')
        row.className = 'wk-heatmap-tooltip__name'
        row.textContent = `• ${name}`
        namesWrap.append(row)
      }
      if (tip.names.length > 4) {
        const more = document.createElement('div')
        more.className = 'wk-heatmap-tooltip__more'
        more.textContent = `…and ${tip.names.length - 4} more`
        namesWrap.append(more)
      }
      panel.append(namesWrap)
    }

    const arrow = document.createElement('div')
    arrow.className = 'wk-heatmap-tooltip__arrow'

    inner.append(panel, arrow)
    bubble.append(inner)
  }

  function layoutBubble(bubble: HTMLElement, anchor: HTMLElement, tip: WkTipPayload) {
    const r = anchor.getBoundingClientRect()
    const gap = 8
    const pad = 6
    const cellCenterX = r.left + r.width / 2

    const w = bubble.offsetWidth
    const h = bubble.offsetHeight

    let left = cellCenterX - w / 2
    if (tip.columnIndex < 4)
      left = r.left
    else if (tip.columnIndex > tip.totalColumns - 5)
      left = r.right - w

    left = Math.max(pad, Math.min(left, window.innerWidth - w - pad))
    const top = Math.max(pad, r.top - gap - h)

    bubble.style.left = `${left}px`
    bubble.style.top = `${top}px`

    const inner = bubble.querySelector('.wk-heatmap-tooltip__inner') as HTMLElement | null
    const arrow = bubble.querySelector('.wk-heatmap-tooltip__arrow') as HTMLElement | null
    if (!inner || !arrow)
      return

    const tw = inner.offsetWidth
    const bl = bubble.getBoundingClientRect().left
    let ax = cellCenterX - bl
    if (tip.columnIndex < 4)
      ax = 10
    else if (tip.columnIndex > tip.totalColumns - 5)
      ax = Math.max(10, tw - 10)
    else
      ax = Math.max(10, Math.min(ax, tw - 10))

    arrow.style.left = `${ax}px`
  }

  function initWkHeatmapRoot(root: HTMLElement) {
    if (root.dataset.wkTipBound)
      return
    root.dataset.wkTipBound = '1'

    const bubbleNode = root.querySelector('.wk-heatmap-tooltip')
    const scrollNode = root.querySelector('[data-workout-contrib-scroll]')
    if (!(bubbleNode instanceof HTMLElement) || !(scrollNode instanceof HTMLElement))
      return
    const bubbleEl = bubbleNode
    const scrollEl = scrollNode

    let anchorEl: HTMLElement | null = null

    function hide() {
      anchorEl = null
      bubbleEl.classList.remove('wk-heatmap-tooltip--open')
    }

    function show(el: HTMLElement) {
      const tip = parseWkTip(el)
      if (!tip)
        return
      anchorEl = el
      bubbleEl.classList.add('wk-heatmap-tooltip--open')
      fillTooltipContent(bubbleEl, tip)
      layoutBubble(bubbleEl, el, tip)
      requestAnimationFrame(() => {
        if (anchorEl === el)
          layoutBubble(bubbleEl, el, tip)
      })
    }

    root.addEventListener('pointerover', (e) => {
      const el = closestWkTip(e.target)
      if (!el || !(el instanceof HTMLElement))
        return
      if (el === anchorEl && bubbleEl.classList.contains('wk-heatmap-tooltip--open'))
        return
      show(el)
    })

    root.addEventListener('pointerout', (e) => {
      const rt = e.relatedTarget as Node | null
      if (anchorEl && rt && anchorEl.contains(rt))
        return
      const leaveFrom = (e.target as Element).closest('[data-wk-tip]')
      if (!leaveFrom || leaveFrom !== anchorEl)
        return
      if (rt && leaveFrom.contains(rt))
        return
      hide()
    })

    root.addEventListener('focusin', (e) => {
      const el = closestWkTip(e.target)
      if (el instanceof HTMLElement)
        show(el)
    })

    root.addEventListener('focusout', (e) => {
      const next = e.relatedTarget as Element | null
      const nCell = closestWkTip(next)
      if (nCell instanceof HTMLElement) {
        show(nCell)
        return
      }
      hide()
    })

    scrollEl.addEventListener('scroll', hide, { passive: true })
  }

  function dismissAllWkHeatmapTooltips() {
    document.querySelectorAll('.wk-heatmap-tooltip--open').forEach((el) => {
      el.classList.remove('wk-heatmap-tooltip--open')
    })
  }

  function initAllWkHeatmapRoots() {
    document.querySelectorAll('[data-wk-heatmap-root]').forEach((el) => {
      initWkHeatmapRoot(el as HTMLElement)
    })
  }

  function scrollWorkoutGridToRecent() {
    document.querySelectorAll('[data-workout-contrib-scroll]').forEach((el) => {
      const node = el as HTMLElement
      node.scrollLeft = node.scrollWidth - node.clientWidth
    })
  }

  scrollWorkoutGridToRecent()
  requestAnimationFrame(() => {
    requestAnimationFrame(scrollWorkoutGridToRecent)
  })
  initAllWkHeatmapRoots()

  const htmlRoot = document.documentElement
  if (!htmlRoot.dataset.wkContribScrollBound) {
    htmlRoot.dataset.wkContribScrollBound = ''
    document.addEventListener('astro:page-load', () => {
      scrollWorkoutGridToRecent()
      initAllWkHeatmapRoots()
    })
    document.addEventListener('astro:after-swap', () => {
      scrollWorkoutGridToRecent()
      initAllWkHeatmapRoots()
    })
  }

  if (!htmlRoot.dataset.wkTipDismissBound) {
    htmlRoot.dataset.wkTipDismissBound = ''
    window.addEventListener('scroll', dismissAllWkHeatmapTooltips, { capture: true, passive: true })
    window.addEventListener('resize', dismissAllWkHeatmapTooltips)
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape')
        dismissAllWkHeatmapTooltips()
    })
  }
</script>
