{
  "name": "yuler.dev",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "pnpm@10.28.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "check": "astro check",
    "astro": "astro",
    "up": "npx taze -I",
    "autocorrect": "autocorrect --fix src/content",
    "create:post": "node scripts/create-post.mjs",
    "export:pdf": "npm run build && node scripts/export-post-pdf.mjs",
    "test:strava": "npx tsx --env-file=.env scripts/test-strava.mjs",
    "sync:strava:activities": "npx tsx --env-file=.env scripts/sync-strava-activities.mjs",
    "commit": "opencode run git commit"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.6",
    "@astrojs/mdx": "^4.3.13",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.18",
    "@yuler/utils": "^0.3.1",
    "astro": "^5.17.1",
    "date-fns": "^4.1.0",
    "leaflet": "^1.9.4",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "playwright": "^1.58.2",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0"
  }
}